// The 8 steps of `scripts/deploy.sh full`, and why 4 and 6 are split.
// Regenerate with `make diagrams` (do not hand-edit the PNG).
digraph deploy {
  rankdir=TB;
  bgcolor="white";
  nodesep=0.35;
  ranksep=0.32;

  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11,
        color="#4a5568", fillcolor="#f7fafc", fontcolor="#1a202c", margin="0.22,0.12"];
  edge [fontname="Helvetica", fontsize=9, color="#4a5568", fontcolor="#2d3748"];

  s1 [label="1  validate bundle\n(prod: require JOB_RUN_AS_SP)"];
  s2 [label="2  bundle deploy\nLakebase · catalog · secret scope · job · app"];
  s3 [label="3  seed GITHUB_TOKEN\nskipped with a warning if unset"];
  s4 [label="4  migrate schema\nas deploying identity, NO grants",
      fillcolor="#fffaf0", color="#c05621"];
  s5 [label="5  bundle run — activate app\npoll for ACTIVE (15s × 10)",
      fillcolor="#fffaf0", color="#c05621"];
  s6 [label="6  apply grants\napp SP read · job SP write (prod)",
      fillcolor="#fffaf0", color="#c05621"];
  s7 [label="7  index\nonly if repos_to_index is non-empty"];
  s8 [label="8  print app URL\n+ OAuth app-connection reminder"];

  fallback [label="first-activation fallback\ndatabricks apps deploy --source-code-path\nthen re-run + re-probe",
            shape=note, fillcolor="#fff5f5", color="#c53030", fontsize=10];

  // weight pins steps 1-8 to a straight spine so the fallback branch pulls off to
  // the side instead of bending the main path.
  s1 -> s2 -> s3 -> s4 -> s5 -> s6 -> s7 -> s8 [weight=100];
  s5 -> fallback [label="  never ACTIVE  ", style=dashed, color="#c53030", fontcolor="#c53030"];
  fallback -> s6 [style=dashed, color="#c53030"];

  { rank=same; s5; fallback; }
}
