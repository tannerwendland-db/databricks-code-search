// Data flow: GitHub -> indexing job -> Lakebase -> MCP app -> client.
// Vertical on purpose: a left-to-right chain renders ~2300px wide, which GitHub
// downscales until the labels are unreadable.
// Regenerate with `make diagrams` (do not hand-edit the PNG).
digraph architecture {
  rankdir=TB;
  bgcolor="white";
  nodesep=0.3;
  ranksep=0.42;

  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11,
        color="#4a5568", fillcolor="#f7fafc", fontcolor="#1a202c", margin="0.24,0.13"];
  edge [fontname="Helvetica", fontsize=9, color="#4a5568", fontcolor="#2d3748"];

  github  [label="GitHub", fillcolor="#edf2f7"];
  job     [label="indexing job\nserverless · every 12h", fillcolor="#e6f0fa", color="#2b6cb0"];
  db      [label="Lakebase Postgres\nrepos · files · symbols · chunks",
           fillcolor="#e6f0fa", color="#2b6cb0"];
  app     [label="MCP server\nDatabricks App", fillcolor="#e6f0fa", color="#2b6cb0"];
  client  [label="MCP client\nagent", fillcolor="#edf2f7"];

  github -> job    [label=" tarball @ SHA"];
  job    -> db     [label=" one txn, then mark-and-sweep"];
  db     -> app    [label=" SELECT · app SP, read-only"];
  app    -> client [label=" streamable HTTP /mcp · OAuth", dir=both];
}
