# node_modules is also covered by the root .gitignore; repeated here so this directory is
# self-explanatory on its own.
node_modules/

# TypeScript project-reference build artifacts (tsc -b emits these next to vite.config.ts
# because tsconfig.node.json is a referenced project and TS requires *some* emit for its
# incremental build graph -- see tsconfig.node.json). Regenerated by `npm run build`; never
# hand-edited.
*.tsbuildinfo
vite.config.js
vite.config.d.ts
